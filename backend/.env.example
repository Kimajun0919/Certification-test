# ── Database backend ────────────────────────────────────────────────────────
# "memory"  → in-memory store (default; data lost on restart)
# "sheets"  → Google Sheets persistence
DATABASE_BACKEND=memory

# ── Google Sheets (only needed when DATABASE_BACKEND=sheets) ─────────────────
GOOGLE_SHEETS_ID=your_spreadsheet_id_here
GOOGLE_SA_KEY_FILE=service_account.json   # path to downloaded JSON key

# ── Frontend URL (used to build QR links) ───────────────────────────────────
FRONTEND_BASE_URL=http://localhost:5173

# ── CORS allowed origins (comma-separated) ──────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
